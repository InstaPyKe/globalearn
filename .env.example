# Server Configuration
PORT=5000
JWT_SECRET=your_jwt_secret_key_here
NODE_ENV=production

# Database Configuration
# Railway automatically provides DATABASE_URL when you link a Postgres service.
# Format: postgres://user:password@host:port/database
# On Railway Dashboard, set DATABASE_URL to: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgres://postgres:password@localhost:5432/globalearn

# Local Fallback (Used if DATABASE_URL is not provided)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=globalearn
DB_PASSWORD=password
DB_PORT=5432

# M-Pesa Configuration
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=